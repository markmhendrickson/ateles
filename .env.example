# Ateles environment variables
# Copy to ~/.config/ateles/.env (or wherever your daemon's EnvFile points).
# Never commit a file with real values.

# ─── Neotoma ─────────────────────────────────────────────────────────────────

# Bearer token for Neotoma API authentication (required by all daemons)
NEOTOMA_BEARER_TOKEN=

# Neotoma API base URL (defaults to https://neotoma.markmhendrickson.com if unset)
NEOTOMA_BASE_URL=

# ─── Operator identity (operator-specific — never hardcode in daemon code) ───
# Per the Ateles architecture, operator contact details belong in env (or
# parquet), never baked into code. Daemons that brief, notify, or research on
# the operator's behalf read these.

# Operator full name (e.g. used in Cotinga meeting-prep prompts)
OPERATOR_NAME=

# Operator primary email / Google Calendar primary calendar ID
OPERATOR_EMAIL=

# Neotoma entity ID of the canonical Ateles plan (live-convergence lookups).
# Default: ent_99ace4dd6673aa36ed08b1fe
ATELES_PLAN_ENTITY_ID=ent_99ace4dd6673aa36ed08b1fe

# ─── Telegram (Monedula + general notifications) ─────────────────────────────

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Chat ID of the conversation the bot should post to
TELEGRAM_CHAT_ID=

# Allowed Telegram user ID (Monedula ignores commands from other users)
TELEGRAM_ALLOWED_USER_ID=

# Message thread (topic) ID for Monedula payment notifications
# Env var was previously TELEGRAM_TOPIC_PAYMENTS — legacy name still accepted
TELEGRAM_TOPIC_MONEDULA=

# ─── Wise (WiseTransferHandler) ──────────────────────────────────────────────

# Wise API token (required for any PaymentProfile with payment_type=wise)
WISE_API_TOKEN=

# ─── Monedula payment profiles ───────────────────────────────────────────────
# Comma-separated list of profile prefixes. Each prefix drives a set of
# <PREFIX>_* env vars below. Add as many profiles as needed.
# Example: MONEDULA_PROFILES=THERAPY,YOGA

MONEDULA_PROFILES=

# Template for each profile (replace PREFIX with your prefix, e.g. THERAPY):
#
# PREFIX_LABEL=                   # Human-readable label for Telegram messages
# PREFIX_CALENDAR_KEYWORDS=       # Comma-separated keywords to match calendar event titles
# PREFIX_PAYMENT_TYPE=            # "wise" or "btc"
# PREFIX_AMOUNT_EUR=              # Transfer amount in EUR (integer)
#
# Wise-specific:
# PREFIX_CONTACT_ID=              # Neotoma contact_id prefix for IBAN lookup
# PREFIX_CONTACT_CATEGORY=        # Fallback: contacts.parquet category
# PREFIX_CONTACT_PLATFORM=        # Fallback: contacts.parquet platform
# PREFIX_WISE_REFERENCE=          # Wise transfer reference string
#
# BTC-specific:
# PREFIX_BTC_ADDRESS=             # Destination BTC address
#
# Neotoma task (optional):
# PREFIX_NEOTOMA_TASK_ID=         # Task entity ID to update due_date after payment
# PREFIX_TASK_KEYWORDS=           # Comma-separated keywords for task search fallback

# ─── Cotinga (daily event-prep briefing daemon) ──────────────────────────────

# Comma-separated Google Calendar IDs to include in the daily brief (primary +
# any shared/family calendars). When unset, defaults to OPERATOR_EMAIL alone.
# Example: COTINGA_CALENDAR_IDS=you@gmail.com,family123@group.calendar.google.com
COTINGA_CALENDAR_IDS=

# Telegram topic (thread) ID for Cotinga briefings (optional)
TELEGRAM_TOPIC_COTINGA=

# ─── lib/notify/ (Apprise notification routing) ──────────────────────────────

# Neotoma entity ID for the priority_rubric config entity
# Default rubric entity: ent_29ca079940c1e996a8c782f2
PRIORITY_RUBRIC_ENTITY_ID=ent_29ca079940c1e996a8c782f2

# ─── lib/daemon_runtime/ (agent_definition + AAuth) ──────────────────────────

# Optional: explicit Neotoma entity IDs for each daemon's agent_definition.
# If unset, daemon_runtime searches by name. These are set once after Phase 1.
MONEDULA_AGENT_DEFINITION_ID=ent_26e45f38f53798eb42961a69
NEOTOMA_AGENT_DEFINITION_ID=ent_c5c8d28bd420ca094f9d5a48
APUS_AGENT_DEFINITION_ID=ent_692e8533840be7195240a1e4

# ─── Transcription extraction (Cyphorhinus / Piculet) ────────────────────────

# Canonical "Neotoma, Inc." company entity that product mentions get related to
# during transcription extraction. Override to point a fork / different graph at
# its own company entity. Default: ent_44835c5b0047ce26ffbe40bc
NEOTOMA_COMPANY_ENTITY_ID=ent_44835c5b0047ce26ffbe40bc

# ─── Apus (mirror webhook daemon) ────────────────────────────────────────────

# HMAC-SHA256 secret for verifying Neotoma webhook signatures (recommended)
APUS_WEBHOOK_SECRET=

# Port Apus listens on locally (Cloudflare Tunnel proxies apus.markmhendrickson.com → this)
# Default: 8741
APUS_PORT=8741

# Local filesystem paths to the ateles repos (used by Apus for git commits)
ATELES_REPO_PATH=
ATELES_PRIVATE_REPO_PATH=

# Git author identity used for mirror commits
ATELES_AGENT_GIT_NAME=ateles-agent
ATELES_AGENT_GIT_EMAIL=

# Telegram topic for Apus notifications (optional)
TELEGRAM_TOPIC_APUS=

# Telegram topic for neotoma-agent notifications (optional)
TELEGRAM_TOPIC_NEOTOMA_AGENT=

# Path to ateles-private/keys/ directory (AAuth keypairs, Phase 1+)
# Default: ../ateles-private/keys/ relative to the ateles repo root
ATELES_PRIVATE_KEYS_DIR=

# ─── Data directory (shared libs) ────────────────────────────────────────────

# Root directory for parquet data files (contacts.parquet, etc.)
DATA_DIR=
