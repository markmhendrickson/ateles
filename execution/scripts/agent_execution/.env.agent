# Gateway is now managed by ai.openclaw.gateway launchd service (installed 2026-05-27)
# The proper gateway plist is: ~/Library/LaunchAgents/ai.openclaw.gateway.plist
# This service is kept for compatibility but the gateway start is a no-op here since ai.openclaw.gateway handles it
OPENCLAW_AGENT_CORE_CMD="echo 'Gateway managed by ai.openclaw.gateway launchd service'"
