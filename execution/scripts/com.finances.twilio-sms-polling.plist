<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.finances.twilio-sms-polling</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/Users/markmhendrickson/Projects/personal/scripts/twilio_sms_polling_wrapper.sh</string>
    </array>
    
    <key>WorkingDirectory</key>
    <string>/Users/markmhendrickson/Projects/personal</string>
    
    <key>RunAtLoad</key>
    <true/>
    
    <key>StartCalendarInterval</key>
    <array>
        <!-- Run daily at 2 AM -->
        <dict>
            <key>Hour</key>
            <integer>2</integer>
            <key>Minute</key>
            <integer>0</integer>
        </dict>
    </array>
    
    <key>StandardOutPath</key>
    <string>/Users/markmhendrickson/Projects/personal/data/logs/twilio_sms_polling.log</string>
    
    <key>StandardErrorPath</key>
    <string>/Users/markmhendrickson/Projects/personal/data/logs/twilio_sms_polling.error.log</string>
    
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin</string>
    </dict>
</dict>
</plist>






