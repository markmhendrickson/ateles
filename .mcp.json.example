{
  "mcpServers": {
    "github_harness": {
      "command": "node",
      "args": [
        "/path/to/ateles/execution/mcp/github_harness/dist/index.js"
      ],
      "env": {
        "GITHUB_HARNESS_DEBUG": "0"
      }
    },
    "notion": {
      "command": "notion-mcp-server",
      "args": [],
      "env": {
        "OPENAPI_MCP_HEADERS": "{\"Authorization\": \"Bearer ntn_YOUR_INTEGRATION_TOKEN\", \"Notion-Version\": \"2022-06-28\"}"
      }
    }
  }
}
