# Sensitive credentials and configuration
.mcp.json
.env
.env.local
.env.*.local
.env.swp
.env.backups/
execution/.env.backups/
!.env.example

# SOPS: encrypted snapshots (secrets/*.sops.env) and the env-map ARE committed;
# any plaintext staging next to them is NOT.
secrets/*.plain.env
secrets/*.decrypted
secrets/*.plaintext
!secrets/*.sops.env

# age private keys must never be committed (canonical copy lives in 1Password)
*.agekey
keys.txt
.creds/
credentials.json
*.pem
*.key

# launchd plists contain operator-absolute home paths (e.g. /Users/<name>/...).
# New daemons keep them local-only; existing tracked plists on main are
# grandfathered and not retroactively scrubbed by this rule.
execution/daemons/gorilla/com.ateles.gorilla.plist

__pycache__/
*.pyc
*.pyo
*.pyd
.Python
node_modules/

# Playwright authentication state
playwright/.auth/
venv
.venv*/
execution/venv
execution/homeassistant-venv

# Foundation local overrides
foundation-config.local.yaml

# Temporary files (may contain sensitive data)
tmp

# Tesseract language data files (large binary files)
*.traineddata

# Cursor configuration (generated symlinks and user-specific settings)
.cursor/rules/
.cursor/commands/
.cursor/environment.json
.cursor/error_reports/

data.creds/
data/

# Website cache (generated from Neotoma export at build time; do not commit)
execution/website/markmhendrickson/react-app/cache/

# Neotoma plan mirrors (local only, regenerated via `neotoma mirror rebuild --profile ateles-plans`)
docs/plans/

# Private handler files (superseded by generic handlers — contain personal config)
execution/daemons/monedula/handlers/therapy.py
execution/daemons/monedula/handlers/yoga.py

# mic-recorder directory (superseded by strix daemon)
execution/daemons/mic-recorder/

# launchd plists contain operator-absolute home paths (e.g. /Users/<name>/...).
# All daemon plists are local-only; never commit them.
execution/daemons/*/*.plist

# Daemon runtime state
execution/daemons/**/.monedula_last_run
execution/daemons/**/.monedula_tg_offset

# Private docs submodule (not part of public repo)
docs/private/

# macOS
.DS_Store
.drafts/
download.html

# Daemon runtime state — written by live daemons into their checkout; must never
# dirty the working tree (causes rebase/stash churn in the shared checkout).
# Durable fix relocates these to ~/.local/state/ateles/; these ignores are the
# belt-and-suspenders so a daemon write can't block interactive git work.
execution/daemons/*/seen_files.json
execution/daemons/*/seen_meeting_files.json
execution/daemons/*/*_state.json
execution/daemons/*/.*_state.json
execution/daemons/*/.*_last_run
execution/daemons/*/*_last_run
